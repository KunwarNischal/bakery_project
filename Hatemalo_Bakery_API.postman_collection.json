  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-save tokens for easier testing",
          "if (pm.response.code === 200 || pm.response.code === 201) {",
          "  try {",
          "    const data = pm.response.json();",
          "    if (data.accessToken) {",
          "      // Detect if it's admin or customer based on isAdmin flag",
          "      if (data.isAdmin) {",
          "        pm.environment.set('admin_token', data.accessToken);",
          "        console.log('Admin token saved');",
          "      } else {",
          "        pm.environment.set('customer_token', data.accessToken);",
          "        console.log('Customer token saved');",
          "      }",
          "    }",
          "  } catch (err) {",
          "    console.log('Could not parse response');",
          "  }",
          "}"
        ]
      }
    }
