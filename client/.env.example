# Hatemalo Bakery Frontend Environment Configuration
# Copy this file to .env and replace with your actual values

# API Configuration
# Base URL for the backend API
VITE_API_URL=http://localhost:5000/api

# Feature Flags
# Enable or disable features globally
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_GUEST_CHECKOUT=true

# Business Logic Thresholds
# Free delivery threshold amount in Rs
VITE_FREE_DELIVERY_THRESHOLD=5000
# Standard delivery fee amount in Rs
VITE_STANDARD_DELIVERY_FEE=300

# UI Configuration
# Number of items per page for customer-facing lists
VITE_PAGINATION_LIMIT=12
# Number of items per page for admin tables
VITE_ADMIN_PAGINATION_LIMIT=20
